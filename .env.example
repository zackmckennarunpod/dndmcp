# FORGE env. Copy to .env (gitignored) or rely on macOS Keychain.
# forge.load_env(profile) sets the 3 Flash hosts automatically per profile.

# Required: Runpod API key. If unset, forge falls back to keychain `runpod-api-key-<profile>`.
RUNPOD_API_KEY=

# Which control plane to target: prod (default) or dev. CONFIRM which the hackathon uses.
FORGE_PROFILE=prod

# Optional: where forge persists its registry + minted tool code (default ./.forge)
# FORGE_STATE_DIR=.forge

# Optional: override GPU $/hr rates for the cost dashboard (verify against current pricing)
# FORGE_RATES_JSON=./rates.json
